<style>
  .timeline-container {
    width: 100%;
    padding: 2rem;
    box-sizing: border-box;
  }

  .timeline-row {
    position: relative;
    margin-bottom: 2rem;
    height: 2rem;
  }

  .timeline-label {
    position: absolute;
    left: 0;
    top: -1.5rem;
    font-weight: bold;
  }

  .timeline-line {
    position: relative;
    height: 100%;
    border-top: 2px solid #ccc;
  }

  .timeline-dot {
    position: absolute;
    top: -0.5rem;
    width: 1rem;
    height: 1rem;
    background-color: #FF6F61; /* Primary color */
    border-radius: 50%;
    transform: translateX(-50%);
    transition: background-color 0.3s;
  }

  .timeline-dot:hover {
    background-color: #e65c50; /* Darker shade on hover */
  }
</style>
