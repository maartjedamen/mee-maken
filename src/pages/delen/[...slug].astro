---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("events");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, subtitle, cadence, status, tags, cta, relatedThinking, heroImage } = entry.data;
---

<BaseLayout title={title}>
  <main class="max-w-4xl mx-auto px-6 md:px-12">
    <header class="py-8 md:py-10">
      <a href="/delen" class="a-link no-underline hover:underline font-ui">
        ← Terug naar Delen
      </a>

      <h1 class="mt-5 text-xl md:text-3xl font-semibold text-fg font-ui">{title}</h1>

      {subtitle ? <p class="mt-3 measure text-base text-muted">{subtitle}</p> : null}

      {heroImage ? (
        <div class="mt-6">
          <img
            src={heroImage}
            alt=""
            loading="lazy"
            class="w-full rounded-2xl border"
            style="border-color: rgb(var(--c-fg) / var(--border-alpha));"
          />
        </div>
      ) : null}

      <div class="mt-5 flex flex-wrap gap-2">
        {cadence ? <span class="pill">{cadence}</span> : null}
        {status ? <span class="pill">{status}</span> : null}
        {tags?.map((t) => <span class="pill">{t}</span>)}
      </div>

      <div class="mt-8 border-t" style="border-color: rgb(var(--c-fg) / var(--border-alpha));" />
    </header>

    <article class="prose">
      <Content />
    </article>

    {cta ? (
      <section class="mt-10">
        <div class="card p-6 text-center">
          <p class="font-semibold mb-2 text-brand font-ui">{cta.label}</p>
          <a href={cta.href} class="btn-accent">Aanmelden / contact</a>
        </div>
      </section>
    ) : null}

    {relatedThinking?.length ? (
      <section class="mt-10">
        <div class="card p-6">
          <h2 class="font-ui text-sm uppercase tracking-wider text-muted">Ruggengraat</h2>
          <p class="mt-2 text-sm text-fg">Gerelateerd denken:</p>
          <ul class="mt-3 space-y-2">
            {relatedThinking.map((href) => (
              <li>
                <a href={href} class="a-link">{href.replace("/denken/", "")}</a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    ) : null}
  </main>
</BaseLayout>
