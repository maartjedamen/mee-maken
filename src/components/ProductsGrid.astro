---
/**
 * Products grid for the Doen page.
 * - Standalone component (like InteractiveCV)
 * - Source of truth: content collection `producten`
 * - Visual language: same base card as Denken, with a Doen accent bar (4× hairline)
 */
import { getCollection } from "astro:content";

const entries = await getCollection("producten");

// Keep it predictable: alphabetical, unless you later add an explicit `order` field.
entries.sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return a.data.title.localeCompare(b.data.title);
});
---

<section aria-label="Producten en diensten" class="py-10 md:py-12">
  <div class="grid gap-6 md:gap-8 md:grid-cols-2">
    <div class="md:col-span-4">
      <h2 class="font-ui text-sm uppercase tracking-wider text-muted">
        Producten & diensten
      </h2>
    </div>

    <div class="md:col-span-8 space-y-4">
      <p class="text-base text-fg max-w-prose">
        Dit zijn de vormen waarin mijn werk nu het meest concreet wordt. Alles is
        geworteld in het denken: initiatief, impact en rechtvaardige afweging.
      </p>

      <div class="grid gap-6 md:gap-8 md:grid-cols-2">
        {entries.map((e) => (
          <a href={`/doen/${e.slug}`} class="card card-hover card-doen p-7 transition">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-ui text-base md:text-lg font-semibold text-brand">
                {e.data.title}
              </h3>
              <span aria-hidden="true" class="text-muted">→</span>
            </div>

            {e.data.subtitle ? <p class="mt-2 text-fg">{e.data.subtitle}</p> : null}

            <div class="mt-4 flex flex-wrap gap-2">
              {e.data.status ? <span class="pill">{e.data.status}</span> : null}
              {(e.data.tags ?? []).map((t) => (
                <span class="pill">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
